   "source": [
    "# ReviewIQ — Notebook 02: Exploratory Data Analysis\n",
    "\n",
    "Understand the dataset before training:\n",
    "- Rating distributions per category\n",
    "- Review length analysis\n",
    "- Temporal trends\n",
    "- Verified vs unverified patterns\n",
    "- Top ASINs by review volume\n",
    "- Fake review signal exploration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install pandas matplotlib seaborn wordcloud plotly -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "from pathlib import Path\n",
    "from wordcloud import WordCloud\n",
    "\n",
    "PROCESSED_DIR = Path(\"../../data/processed\")\n",
    "PLOTS_DIR = Path(\"../../reports/eda_plots\")\n",
    "PLOTS_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "df = pd.read_parquet(PROCESSED_DIR / \"reviews_clean_all.parquet\")\n",
    "print(f\"Loaded {len(df):,} reviews\")\n",
    "df.head(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 1. Star Rating Distribution per Category ──────────────────────────────────\n",
    "fig, axes = plt.subplots(2, 4, figsize=(20, 10))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for i, (cat, grp) in enumerate(df.groupby(\"category\")):\n",
    "    ax = axes[i]\n",
    "    grp[\"star_rating\"].value_counts().sort_index().plot(kind=\"bar\", ax=ax, color=\"steelblue\")\n",
    "    ax.set_title(cat.replace(\"_\", \" \"), fontsize=10)\n",
    "    ax.set_xlabel(\"Stars\")\n",
    "    ax.set_ylabel(\"Count\")\n",
    "    ax.tick_params(rotation=0)\n",
    "\n",
    "plt.suptitle(\"Star Rating Distribution by Category\", fontsize=14, y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.savefig(PLOTS_DIR / \"rating_distribution.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2. Review Length Analysis ─────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# By star rating\n",
    "df.groupby(\"star_rating\")[\"word_count\"].median().plot(\n",
    "    kind=\"bar\", ax=axes[0], color=\"coral\"\n",
    ")\n",
    "axes[0].set_title(\"Median Word Count by Star Rating\")\n",
    "axes[0].set_xlabel(\"Stars\")\n",
    "axes[0].set_ylabel(\"Median Words\")\n",
    "\n",
    "# Distribution\n",
    "df[\"word_count\"].clip(0, 500).hist(bins=50, ax=axes[1], color=\"steelblue\", edgecolor=\"white\")\n",
    "axes[1].set_title(\"Word Count Distribution (capped at 500)\")\n",
    "axes[1].set_xlabel(\"Word Count\")\n",
    "axes[1].set_ylabel(\"Frequency\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(PLOTS_DIR / \"review_length.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nWord count stats:\")\n",
    "print(df[\"word_count\"].describe().round(1))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 3. Temporal Trends ────────────────────────────────────────────────────────\n",
    "if \"review_date\" in df.columns:\n",
    "    monthly = (\n",
    "        df.set_index(\"review_date\")\n",
    "        .resample(\"ME\")[[\"star_rating\"]]\n",
    "        .agg({\"star_rating\": [\"mean\", \"count\"]})\n",
    "        .round(3)\n",
    "    )\n",
    "    monthly.columns = [\"avg_rating\", \"review_count\"]\n",
    "    monthly = monthly.reset_index()\n",
    "\n",
    "    fig = go.Figure()\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=monthly[\"review_date\"], y=monthly[\"avg_rating\"],\n",
    "        name=\"Avg Rating\", yaxis=\"y1\", line=dict(color=\"steelblue\")\n",
    "    ))\n",
    "    fig.add_trace(go.Bar(\n",
    "        x=monthly[\"review_date\"], y=monthly[\"review_count\"],\n",
    "        name=\"Review Count\", yaxis=\"y2\", opacity=0.3, marker_color=\"coral\"\n",
    "    ))\n",
    "    fig.update_layout(\n",
    "        title=\"Monthly Review Volume & Avg Rating\",\n",
    "        yaxis=dict(title=\"Avg Rating\", range=[1, 5]),\n",
    "        yaxis2=dict(title=\"Review Count\", overlaying=\"y\", side=\"right\"),\n",
    "        legend=dict(x=0, y=1.1, orientation=\"h\")\n",
    "    )\n",
    "    fig.show()\n",
    "    fig.write_html(str(PLOTS_DIR / \"temporal_trends.html\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 4. Verified vs Unverified Purchase Analysis ───────────────────────────────\n",
    "# Key signal for fake review detection\n",
    "if \"verified_purchase\" in df.columns:\n",
    "    vp_stats = df.groupby(\"verified_purchase\").agg(\n",
    "        avg_rating=(\"star_rating\", \"mean\"),\n",
    "        avg_words=(\"word_count\", \"mean\"),\n",
    "        count=(\"review_text\", \"count\"),\n",
    "        pct_5star=(\"star_rating\", lambda x: (x == 5).mean() * 100),\n",
    "        pct_1star=(\"star_rating\", lambda x: (x == 1).mean() * 100),\n",
    "    ).round(2)\n",
    "\n",
    "    print(\"Verified vs Unverified Purchase Stats:\")\n",
    "    print(vp_stats.to_string())\n",
    "\n",
    "    # Rating distribution comparison\n",
    "    fig, ax = plt.subplots(figsize=(10, 5))\n",
    "    for vp, grp in df.groupby(\"verified_purchase\"):\n",
    "        dist = grp[\"star_rating\"].value_counts(normalize=True).sort_index() * 100\n",
    "        label = \"Verified\" if vp else \"Unverified\"\n",
    "        dist.plot(kind=\"line\", ax=ax, marker=\"o\", label=label)\n",
    "    ax.set_title(\"Rating Distribution: Verified vs Unverified Purchase\")\n",
    "    ax.set_xlabel(\"Star Rating\")\n",
    "    ax.set_ylabel(\"% of Reviews\")\n",
    "    ax.legend()\n",
    "    plt.savefig(PLOTS_DIR / \"verified_vs_unverified.png\", dpi=150)\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 5. Top ASINs — Most Reviewed Products ─────────────────────────────────────\n",
    "top_asins = (\n",
    "    df.groupby(\"asin\")\n",
    "    .agg(\n",
    "        review_count=(\"review_text\", \"count\"),\n",
    "        avg_rating=(\"star_rating\", \"mean\"),\n",
    "        rating_std=(\"star_rating\", \"std\"),\n",
    "        category=(\"category\", \"first\"),\n",
    "    )\n",
    "    .sort_values(\"review_count\", ascending=False)\n",
    "    .head(20)\n",
    "    .round(3)\n",
    ")\n",
    "\n",
    "print(\"Top 20 ASINs by Review Count:\")\n",
    "print(top_asins.to_string())\n",
    "\n",
    "# These are your best training examples for the competitor model\n",
    "top_asins.to_csv(PLOTS_DIR / \"top_asins.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 6. Fake Review Signal Exploration ────────────────────────────────────────\n",
    "# Signals associated with fake reviews based on research literature:\n",
    "# - Very short reviews with 5 stars\n",
    "# - Unverified purchase + 5 stars\n",
    "# - Burst patterns (many reviews same day)\n",
    "# - Duplicate/near-duplicate text\n",
    "\n",
    "print(\"=== Fake Review Signal Exploration ===\")\n",
    "\n",
    "# Signal 1: Short 5-star unverified\n",
    "if \"verified_purchase\" in df.columns:\n",
    "    suspicious = df[\n",
    "        (df[\"star_rating\"] == 5) &\n",
    "        (~df[\"verified_purchase\"]) &\n",
    "        (df[\"word_count\"] < 10)\n",
    "    ]\n",
    "    print(f\"\\nShort (< 10 words) unverified 5-star reviews: {len(suspicious):,} ({len(suspicious)/len(df)*100:.1f}%)\")\n",
    "\n",
    "# Signal 2: Same day burst per ASIN\n",
    "if \"review_date\" in df.columns:\n",
    "    df[\"review_date_only\"] = df[\"review_date\"].dt.date\n",
    "    daily_counts = df.groupby([\"asin\", \"review_date_only\"]).size()\n",
    "    burst_threshold = 20  # 20+ reviews in one day = suspicious\n",
    "    burst_asins = daily_counts[daily_counts >= burst_threshold]\n",
    "    print(f\"\\nASIN-day pairs with {burst_threshold}+ reviews (burst signal): {len(burst_asins):,}\")\n",
    "    print(burst_asins.sort_values(ascending=False).head(10))\n",
    "\n",
    "# Signal 3: Duplicate review text\n",
    "dup_count = df.duplicated(subset=[\"review_text\"]).sum()\n",
    "print(f\"\\nDuplicate review texts: {dup_count:,} ({dup_count/len(df)*100:.1f}%)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 7. Word Clouds for Positive vs Negative Reviews ───────────────────────────\n",
    "from collections import Counter\n",
    "import re\n",
    "\n",
    "STOPWORDS = {\"the\", \"a\", \"an\", \"is\", \"it\", \"this\", \"i\", \"my\", \"and\", \"or\", \"but\",\n",
    "             \"was\", \"are\", \"be\", \"have\", \"has\", \"to\", \"of\", \"in\", \"for\", \"on\",\n",
    "             \"with\", \"at\", \"by\", \"from\", \"as\", \"not\", \"that\", \"they\", \"we\",\n",
    "             \"you\", \"he\", \"she\", \"so\", \"if\", \"no\", \"do\", \"just\", \"very\"}\n",
    "\n",
    "def get_words(series):\n",
    "    text = \" \".join(series.dropna().sample(min(10000, len(series))).tolist())\n",
    "    words = re.findall(r\"\\b[a-z]{3,}\\b\", text.lower())\n",
    "    return \" \".join(w for w in words if w not in STOPWORDS)\n",
    "\n",
    "pos_text = get_words(df[df[\"star_rating\"] >= 4][\"review_text\"])\n",
    "neg_text = get_words(df[df[\"star_rating\"] <= 2][\"review_text\"])\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(18, 7))\n",
    "\n",
    "WordCloud(width=800, height=400, background_color=\"white\",\n",
    "          colormap=\"YlGn\", max_words=100).generate(pos_text).to_image()\n",
    "wc_pos = WordCloud(width=800, height=400, background_color=\"white\", colormap=\"YlGn\").generate(pos_text)\n",
    "axes[0].imshow(wc_pos)\n",
    "axes[0].set_title(\"Positive Reviews (4-5★)\", fontsize=14)\n",
    "axes[0].axis(\"off\")\n",
    "\n",
    "wc_neg = WordCloud(width=800, height=400, background_color=\"white\", colormap=\"OrRd\").generate(neg_text)\n",
    "axes[1].imshow(wc_neg)\n",
    "axes[1].set_title(\"Negative Reviews (1-2★)\", fontsize=14)\n",
    "axes[1].axis(\"off\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(PLOTS_DIR / \"wordclouds.png\", dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 8. Category Competitive Landscape ────────────────────────────────────────\n",
    "cat_summary = df.groupby(\"category\").agg(\n",
    "    total_reviews=(\"review_text\", \"count\"),\n",
    "    unique_asins=(\"asin\", \"nunique\"),\n",
    "    avg_rating=(\"star_rating\", \"mean\"),\n",
    "    pct_positive=(\"sentiment_label\", lambda x: x.mean() * 100 if x.notna().any() else 0),\n",
    ").round(2)\n",
    "\n",
    "cat_summary = cat_summary.sort_values(\"total_reviews\", ascending=False)\n",
    "print(\"Category Summary:\")\n",
    "print(cat_summary.to_string())\n",
    "\n",
    "# Bubble chart\n",
    "fig = px.scatter(\n",
    "    cat_summary.reset_index(),\n",
    "    x=\"avg_rating\",\n",
    "    y=\"pct_positive\",\n",
    "    size=\"total_reviews\",\n",
    "    text=\"category\",\n",
    "    title=\"Category Landscape: Avg Rating vs % Positive Reviews\",\n",
    "    color=\"unique_asins\",\n",
    "    color_continuous_scale=\"Blues\",\n",
    ")\n",
    "fig.update_traces(textposition=\"top center\")\n",
    "fig.show()\n",
    "fig.write_html(str(PLOTS_DIR / \"category_landscape.html\"))\n",
    "\n",
    "print(\"\\n✅ EDA complete. Plots saved to:\", PLOTS_DIR)"
   ]
  }
 ],
