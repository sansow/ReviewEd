   "source": [
    "# ReviewIQ — Notebook 05: Competitor Intelligence & Aspect Gap Matrix\n",
    "\n",
    "For a given ASIN, compare its aspect-level performance vs top 3 competitors in the same category.\n",
    "\n",
    "### Output\n",
    "- Aspect Gap Matrix (your product vs competitors)\n",
    "- Gap score per aspect dimension\n",
    "- Ranked list of improvement opportunities\n",
    "- Claude API synthesis of actionable insights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install pandas numpy scikit-learn spacy plotly anthropic -q\n",
    "!python -m spacy download en_core_web_sm -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import json\n",
    "import anthropic\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "from pathlib import Path\n",
    "\n",
    "PROCESSED_DIR = Path(\"../../data/processed\")\n",
    "OUTPUTS_DIR = Path(\"../../data/competitor_outputs\")\n",
    "OUTPUTS_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "df = pd.read_parquet(PROCESSED_DIR / \"reviews_clean_all.parquet\")\n",
    "ris_df = pd.read_parquet(Path(\"../../data/ris_outputs/ris_scores.parquet\")).set_index(\"asin\")\n",
    "print(f\"Reviews: {len(df):,} | RIS ASINs: {len(ris_df):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Aspect Sentiment Scorer ───────────────────────────────────────────────────\n",
    "# Score each aspect dimension for an ASIN using keyword + sentiment signals\n",
    "\n",
    "ASPECT_DIMENSIONS = {\n",
    "    \"quality\": {\n",
    "        \"pos\": [\"durable\", \"sturdy\", \"well-made\", \"excellent quality\", \"high quality\", \"great quality\", \"solid\"],\n",
    "        \"neg\": [\"broke\", \"flimsy\", \"cheap\", \"poor quality\", \"bad quality\", \"falls apart\", \"defective\"],\n",
    "    },\n",
    "    \"value\": {\n",
    "        \"pos\": [\"great value\", \"worth it\", \"affordable\", \"reasonable price\", \"good deal\", \"budget friendly\"],\n",
    "        \"neg\": [\"overpriced\", \"too expensive\", \"not worth\", \"rip off\", \"waste of money\", \"costly\"],\n",
    "    },\n",
    "    \"effectiveness\": {\n",
    "        \"pos\": [\"works great\", \"works well\", \"effective\", \"really works\", \"amazing results\", \"works perfectly\"],\n",
    "        \"neg\": [\"doesn't work\", \"ineffective\", \"no results\", \"waste\", \"useless\", \"did nothing\"],\n",
    "    },\n",
    "    \"packaging\": {\n",
    "        \"pos\": [\"well packaged\", \"nice packaging\", \"arrived safely\", \"good packaging\", \"securely packed\"],\n",
    "        \"neg\": [\"damaged packaging\", \"poorly packaged\", \"arrived damaged\", \"broken\", \"leaking\", \"spilled\"],\n",
    "    },\n",
    "    \"shipping\": {\n",
    "        \"pos\": [\"fast shipping\", \"quick delivery\", \"arrived fast\", \"on time\", \"early delivery\"],\n",
    "        \"neg\": [\"slow shipping\", \"late delivery\", \"took forever\", \"delayed\", \"never arrived\"],\n",
    "    },\n",
    "    \"usability\": {\n",
    "        \"pos\": [\"easy to use\", \"user friendly\", \"simple\", \"intuitive\", \"easy to follow\", \"easy setup\"],\n",
    "        \"neg\": [\"confusing\", \"hard to use\", \"complicated\", \"difficult\", \"unclear instructions\"],\n",
    "    },\n",
    "    \"customer_service\": {\n",
    "        \"pos\": [\"great service\", \"helpful\", \"responsive\", \"excellent support\", \"good customer service\"],\n",
    "        \"neg\": [\"terrible service\", \"no response\", \"ignored\", \"unhelpful\", \"poor support\", \"rude\"],\n",
    "    },\n",
    "    \"scent_taste\": {\n",
    "        \"pos\": [\"smells great\", \"delicious\", \"love the scent\", \"tastes good\", \"great flavor\", \"fresh scent\"],\n",
    "        \"neg\": [\"bad smell\", \"terrible taste\", \"awful scent\", \"nasty\", \"chemical smell\", \"bitter\"],\n",
    "    },\n",
    "}\n",
    "\n",
    "def score_aspect(reviews_text: str, aspect_dict: dict) -> float:\n",
    "    \"\"\"Score an aspect from -100 to +100 based on pos/neg keyword matches.\"\"\"\n",
    "    text_lower = reviews_text.lower()\n",
    "    pos_hits = sum(1 for kw in aspect_dict[\"pos\"] if kw in text_lower)\n",
    "    neg_hits = sum(1 for kw in aspect_dict[\"neg\"] if kw in text_lower)\n",
    "    total = pos_hits + neg_hits\n",
    "    if total == 0:\n",
    "        return None  # aspect not mentioned\n",
    "    return ((pos_hits - neg_hits) / total) * 100\n",
    "\n",
    "\n",
    "def get_asin_aspect_scores(asin: str, df: pd.DataFrame) -> dict:\n",
    "    asin_reviews = df[df[\"asin\"] == asin][\"review_text\"].fillna(\"\").str.lower()\n",
    "    combined_text = \" \".join(asin_reviews.tolist())\n",
    "    scores = {}\n",
    "    for aspect, kws in ASPECT_DIMENSIONS.items():\n",
    "        score = score_aspect(combined_text, kws)\n",
    "        if score is not None:\n",
    "            scores[aspect] = round(score, 1)\n",
    "    return scores\n",
    "\n",
    "\n",
    "print(\"Aspect scoring ready\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Find top competitors ──────────────────────────────────────────────────────\n",
    "def get_competitors(target_asin: str, df: pd.DataFrame, ris_df: pd.DataFrame, top_n=3) -> list:\n",
    "    \"\"\"Find top N competitors by RIS score in same category.\"\"\"\n",
    "    if target_asin not in ris_df.index:\n",
    "        raise ValueError(f\"ASIN {target_asin} not in RIS data\")\n",
    "\n",
    "    category = ris_df.loc[target_asin, \"category\"]\n",
    "    category_asins = ris_df[ris_df[\"category\"] == category].copy()\n",
    "\n",
    "    # Exclude target, sort by review count for relevance\n",
    "    asin_review_counts = df.groupby(\"asin\").size().rename(\"review_count\")\n",
    "    category_asins = category_asins.join(asin_review_counts)\n",
    "    category_asins = category_asins[category_asins.index != target_asin]\n",
    "\n",
    "    # Top competitors = high RIS + high review count\n",
    "    category_asins[\"competitor_score\"] = (\n",
    "        category_asins[\"ris_score\"] * 0.5 +\n",
    "        category_asins[\"review_count\"].fillna(0).rank(pct=True) * 50\n",
    "    )\n",
    "    return category_asins.sort_values(\"competitor_score\", ascending=False).head(top_n).index.tolist()\n",
    "\n",
    "\n",
    "print(\"Competitor finder ready\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build Aspect Gap Matrix ───────────────────────────────────────────────────\n",
    "def build_aspect_gap_matrix(target_asin: str, competitor_asins: list, df: pd.DataFrame) -> pd.DataFrame:\n",
    "    all_asins = [target_asin] + competitor_asins\n",
    "    matrix = {}\n",
    "\n",
    "    for asin in all_asins:\n",
    "        label = \"TARGET\" if asin == target_asin else f\"COMP_{competitor_asins.index(asin)+1}\"\n",
    "        matrix[label] = get_asin_aspect_scores(asin, df)\n",
    "\n",
    "    gap_df = pd.DataFrame(matrix).T\n",
    "\n",
    "    # Gap = competitor max - target for each aspect\n",
    "    target_scores = gap_df.loc[\"TARGET\"]\n",
    "    comp_scores = gap_df.drop(\"TARGET\")\n",
    "    gap_df.loc[\"COMP_AVG\"] = comp_scores.mean()\n",
    "    gap_df.loc[\"GAP\"] = gap_df.loc[\"COMP_AVG\"] - gap_df.loc[\"TARGET\"]\n",
    "\n",
    "    return gap_df\n",
    "\n",
    "\n",
    "# Run on a sample ASIN\n",
    "sample_asin = ris_df.sort_values(\"ris_score\").index[len(ris_df)//2]  # median RIS product\n",
    "competitors = get_competitors(sample_asin, df, ris_df)\n",
    "\n",
    "print(f\"Target ASIN: {sample_asin}\")\n",
    "print(f\"Competitors: {competitors}\")\n",
    "\n",
    "gap_matrix = build_aspect_gap_matrix(sample_asin, competitors, df)\n",
    "print(\"\\n=== Aspect Gap Matrix ===\")\n",
    "print(gap_matrix.round(1).to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Visualize Aspect Gap ──────────────────────────────────────────────────────\n",
    "plot_df = gap_matrix.drop(\"GAP\").T.reset_index()\n",
    "plot_df = plot_df.rename(columns={\"index\": \"aspect\"})\n",
    "\n",
    "fig = go.Figure()\n",
    "colors = {\"TARGET\": \"#e74c3c\", \"COMP_1\": \"#3498db\", \"COMP_2\": \"#2ecc71\",\n",
    "          \"COMP_3\": \"#f39c12\", \"COMP_AVG\": \"#9b59b6\"}\n",
    "\n",
    "for col in [c for c in gap_matrix.index if c != \"GAP\"]:\n",
    "    if col in plot_df.columns:\n",
    "        fig.add_trace(go.Scatterpolar(\n",
    "            r=plot_df[col],\n",
    "            theta=plot_df[\"aspect\"],\n",
    "            fill=\"toself\" if col == \"TARGET\" else None,\n",
    "            name=col,\n",
    "            line=dict(color=colors.get(col, \"gray\")),\n",
    "            opacity=0.8,\n",
    "        ))\n",
    "\n",
    "fig.update_layout(\n",
    "    polar=dict(radialaxis=dict(range=[-100, 100])),\n",
    "    title=f\"Aspect Radar: {sample_asin} vs Competitors\",\n",
    "    showlegend=True,\n",
    ")\n",
    "fig.show()\n",
    "fig.write_html(str(OUTPUTS_DIR / f\"radar_{sample_asin}.html\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Claude API: Prescriptive Action Brief ─────────────────────────────────────\n",
    "def generate_action_brief(target_asin: str, gap_matrix: pd.DataFrame,\n",
    "                           ris_df: pd.DataFrame) -> str:\n",
    "    \"\"\"Use Claude to synthesize gap matrix into ranked action brief.\"\"\"\n",
    "\n",
    "    target_ris = ris_df.loc[target_asin] if target_asin in ris_df.index else {}\n",
    "    gap_row = gap_matrix.loc[\"GAP\"].dropna().sort_values(ascending=False)\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "You are a senior Amazon marketplace strategist for ReviewIQ, an AI product intelligence platform.\n",
    "\n",
    "## Target Product\n",
    "- ASIN: {target_asin}\n",
    "- RIS Score: {target_ris.get('ris_score', 'N/A')}/100\n",
    "- Category: {target_ris.get('category', 'N/A')}\n",
    "- Grade: {target_ris.get('ris_grade', 'N/A')}\n",
    "\n",
    "## Aspect Gap vs Top Competitors (positive = competitor leads, negative = you lead)\n",
    "{gap_row.to_string()}\n",
    "\n",
    "## Full Aspect Matrix\n",
    "{gap_matrix.round(1).to_string()}\n",
    "\n",
    "Generate a prescriptive action brief with:\n",
    "1. Top 3 specific actions ranked by revenue impact potential\n",
    "2. For each action: what to fix, why it matters, estimated sales lift range (%), timeframe\n",
    "3. One thing this product does better than competitors (protect this)\n",
    "4. Overall strategic recommendation in 2 sentences\n",
    "\n",
    "Be specific and data-driven. Use the gap scores to justify recommendations.\n",
    "Format as clean JSON with keys: actions (list), strength, strategic_recommendation.\n",
    "\"\"\"\n",
    "\n",
    "    client = anthropic.Anthropic()  # uses ANTHROPIC_API_KEY env var\n",
    "    response = client.messages.create(\n",
    "        model=\"claude-sonnet-4-20250514\",\n",
    "        max_tokens=1200,\n",
    "        messages=[{\"role\": \"user\", \"content\": prompt}],\n",
    "    )\n",
    "\n",
    "    raw = response.content[0].text\n",
    "    # Strip markdown fences if present\n",
    "    clean = raw.replace(\"```json\", \"\").replace(\"```\", \"\").strip()\n",
    "    return json.loads(clean)\n",
    "\n",
    "\n",
    "print(\"Generating AI action brief via Claude API...\")\n",
    "brief = generate_action_brief(sample_asin, gap_matrix, ris_df)\n",
    "print(json.dumps(brief, indent=2))\n",
    "\n",
    "(OUTPUTS_DIR / f\"brief_{sample_asin}.json\").write_text(json.dumps(brief, indent=2))\n",
    "print(f\"\\n✅ Brief saved\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Batch processing utility ──────────────────────────────────────────────────\n",
    "def run_competitor_analysis(asin: str) -> dict:\n",
    "    \"\"\"Full pipeline for one ASIN — used by FastAPI /api/competitor-analysis endpoint.\"\"\"\n",
    "    competitors = get_competitors(asin, df, ris_df)\n",
    "    gap_matrix = build_aspect_gap_matrix(asin, competitors, df)\n",
    "    brief = generate_action_brief(asin, gap_matrix, ris_df)\n",
    "\n",
    "    return {\n",
    "        \"asin\": asin,\n",
    "        \"competitors\": competitors,\n",
    "        \"gap_matrix\": gap_matrix.round(1).to_dict(),\n",
    "        \"action_brief\": brief,\n",
    "        \"ris_score\": float(ris_df.loc[asin, \"ris_score\"]) if asin in ris_df.index else None,\n",
    "    }\n",
    "\n",
    "print(\"✅ Competitor analysis pipeline ready\")"
   ]
  }
 ],
